APP_NAME=UDM Memory Controller
HOST=0.0.0.0
PORT=8080
TIMEZONE=Europe/Berlin
STATE_FILE=/data/state.json
POLL_INTERVAL_SECONDS=300
RESTART_COOLDOWN_SECONDS=3600

SSH_HOST=192.168.1.1
SSH_PORT=22
SSH_USERNAME=root
SSH_PASSWORD=
SSH_PRIVATE_KEY_PATH=/ssh/id_rsa
SSH_PRIVATE_KEY_PASSPHRASE=
SSH_TIMEOUT_SECONDS=15
VERIFY_HOST_KEY=false

MEMORY_MIN_AVAILABLE_MB=700
MEMORY_MIN_AVAILABLE_PERCENT=
MEMORY_CHECK_COMMAND=cat /proc/meminfo
SERVICE_RESTART_COMMAND=unifi-os restart
DRY_RUN_RESTART=false

UI_USERNAME=admin
UI_PASSWORD=changeme

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

GOTIFY_URL=
GOTIFY_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
